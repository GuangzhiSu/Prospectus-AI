{
  "name": "prospectus-ui-monorepo",
  "private": true,
  "description": "Prospectus draft generator — web app + optional local LLM",
  "scripts": {
    "dev": "npm run dev --prefix frontend/web",
    "dev:web": "npm run dev --prefix frontend/web",
    "build": "npm run build --prefix frontend/web",
    "start": "npm run start --prefix frontend/web",
    "lint": "npm run lint --prefix frontend/web",
    "setup:ai": "python3 -m pip install -r ai-module/requirements.txt",
    "desktop:install": "npm install --prefix platform/desktop",
    "desktop:dev": "npm run start --prefix platform/desktop",
    "desktop:pack": "npm run pack --prefix platform/desktop",
    "desktop:dist": "npm run dist --prefix platform/desktop",
    "pack:linux": "bash packaging/linux/build-full-release.sh",
    "pack:mac": "bash packaging/mac/build-full-release.sh",
    "pack:windows-dist": "bash packaging/linux/build-prospectusai-windows.sh",
    "pack:windows": "echo 'Native Windows build (optional): powershell -ExecutionPolicy Bypass -File packaging/windows/build-full-release.ps1'"
  }
}
