      "regex": "^/api/agent1/section/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/agent1/section/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
