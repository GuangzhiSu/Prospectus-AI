# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js (apps/web)
apps/web/.next/
apps/web/out/
apps/web/build/

# Runtime / generated (apps/web)
apps/web/uploads/
apps/web/rag/
apps/web/rag_raw/
apps/web/.progress.json

# Legacy runtime at root (if app was run from root before reorg)
.next/
uploads/
rag/
rag_raw/
.progress.json

# Agent1 output (generated RAG chunks)
agent1_output/

# Agent2 output (generated prospectus sections)
agent2_output/

# IPO prospectus pipeline — run outputs (large extracted/sections JSON, JSONL, raw dumps).
# We do not use a repo-wide *.json rule; that would untrack package.json, tsconfig.json,
# agent2_section_requirements.json, apps/web/*.json, etc.
ipo_prospectus_pipeline/outputs/
ipo_prospectus_pipeline/outputs_*/
prospectus_kg_output/

# HKEX prospectus PDF corpus (large binaries; licensing / redistribution — keep local)
hkex_prospectus/

# Agent1 input data (often large or issuer-specific; keep README tracked)
/data/*.json
/data/*.xlsx
/data/*.csv

# Root-level Word documents (reference packs, often large or internal-only)
/*.docx
docs/*.pdf

# ML / export weights if ever stored in-repo (Hugging Face–style artifacts)
*.safetensors
*.gguf
*.pt
*.pth
*.ckpt
*.onnx
*.h5

# Python (services/local-llm)
.venv/
**/__pycache__/
*.py[cod]
*.pyo
.Python
services/local-llm/.venv/
services/local-llm/chroma/
services/local-llm/rag_raw/

# Env
.env
.env.*
!.env.example

# IDE / OS
.DS_Store
*.pem
*.tsbuildinfo
next-env.d.ts

# Logs / debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
.vercel

# Local “one folder to send” bundle (packaging/bundle-release.*)
dist/ProspectusAI-SharingBundle/

# Temp / lock files
~$*
