{
  "appId": "com.prospectus.ai",
  "productName": "Prospectus AI",
  "copyright": "Copyright © contributors",
  "directories": {
    "output": "release"
  },
  "files": [
    "main.cjs",
    "build/icon.png"
  ],
  "extraResources": [
    {
      "from": "prospectus-bundle",
      "to": "prospectus",
      "filter": ["**/*"]
    }
  ],
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.productivity",
    "icon": "build/icon.png"
  },
  "dmg": {
    "title": "Prospectus AI ${version}",
    "window": {
      "width": 540,
      "height": 380
    },
    "contents": [
      {
        "x": 130,
        "y": 180
      },
      {
        "x": 410,
        "y": 180,
        "type": "link",
        "path": "/Applications"
      }
    ]
  }
}
