# Agent1 output (generated RAG chunks)
agent1_output/

# Agent2 output (generated prospectus sections)
agent2_output/

# IPO prospectus pipeline — run outputs (large extracted/sections JSON, JSONL, raw dumps).
# We do not use a repo-wide *.json rule; that would untrack package.json, tsconfig.json,
# agent2_section_requirements.json, apps/web/*.json, etc.
ipo_prospectus_pipeline/outputs/
ipo_prospectus_pipeline/outputs_*/

# KG outputs — bulk ignored; contract JSON under inputs/ is tracked (see docs/COLLABORATION.md)
prospectus_kg_output/*
!prospectus_kg_output/inputs/
prospectus_kg_output/inputs/*
!prospectus_kg_output/inputs/input_schema.json
!prospectus_kg_output/inputs/input_schema_crosswalk.json
!prospectus_kg_output/inputs/input_schema_sections.json
!prospectus_kg_output/inputs/_coverage_vs_report.md

# Exchange prospectus PDF corpus (large binaries; licensing / redistribution — keep local)
prospectus_corpus/

# Agent1 input data (often large or issuer-specific; keep README + manifest tracked)
/data/*.json
!/data/manifest.json
/data/*.xlsx
/data/*.csv

# Root-level Word documents (reference packs, often large or internal-only)
/*.docx
docs/*.pdf

# ML / export weights if ever stored in-repo (Hugging Face–style artifacts)
