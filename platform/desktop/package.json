{
  "name": "prospectus-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop shell for Prospectus AI",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.prospectus.ai",
    "productName": "Prospectus AI",
    "copyright": "Copyright © contributors",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.cjs",
      "build/icon.png"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Prospectus AI"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Office",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    }
  }
}
