# Modular Prospectus AI — web app environment
# Copy to platform-module/web/.env.local

# Workspace root (data/, agent1_output/, agent2_output/, platform-config/)
PROSPECTUS_ROOT=/absolute/path/to/modular/workspace

# Optional overrides (auto-detected if omitted)
# MODULAR_ROOT=/absolute/path/to/modular
# AI_MODULE_ROOT=/absolute/path/to/modular/ai-module

# Python for AI module (use ai-module venv)
AGENT1_PYTHON=/absolute/path/to/modular/ai-module/.venv/bin/python
AGENT1_MODEL=Qwen/Qwen2.5-3B-Instruct
AGENT1_USE_CPU=1

# Legacy RAG chat (/api/chat) — optional local LLM service
# RAG_PROVIDER=local
# LOCAL_LLM_URL=http://127.0.0.1:8000
